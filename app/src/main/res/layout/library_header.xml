<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@color/spotify_black"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/library_title"
        style="@style/TitleLarge"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/library_title"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/library_search_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/menu_search_button"
        android:padding="12dp"
        android:src="@drawable/ic_search_modern"
        app:tint="@color/white" />

    <ImageButton
        android:id="@+id/library_add_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/menu_add_button"
        android:padding="12dp"
        android:src="@drawable/ic_playlist_add_modern"
        app:tint="@color/white" />

</LinearLayout>
