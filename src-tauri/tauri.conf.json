{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YuMusic",
  "version": "1.7.0",
  "identifier": "com.ysi.yumusic",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YuMusic",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri://localhost localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: http: data:; media-src 'self' asset: https: http: http://asset.localhost; connect-src 'self' https: http:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOWNLOAD/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUxMkJCNDI0M0VFRERGQjYKUldTMjMrMCtKTFFyVVZwSndIRXNNSEhnY1hWc2V4U05Ec0k1L0NDWmFVWU53MVNlZDZNVEMrRS8K",
      "endpoints": [
        "https://github.com/isyuricunha/yumusic/releases/latest/download/latest.json"
      ]
    }
  }
}
